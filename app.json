{
  "expo": {
    "name": "Smart Utility Toolkit",
    "slug": "SmartUtilityToolkit",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/utility-pic.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/utility-pic.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qais.smartutilitytoolkit"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/utility-pic.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.qais.smartutilitytoolkit",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/utility-pic.png"
    },
    "extra": {
      "eas": {
        "projectId": "733409f0-ed3e-497f-8266-1db51c58487f"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}